/*
 * Custom Device Tree for Jio AirFiber derived from IPQ9574 RDP433
 */

/dts-v1/;
#include <dt-bindings/gpio/gpio.h>
#include "ipq9574-jiorouter-common.dtsi"

/ {
    model = "Qualcomm Technologies, Inc. IPQ9574/Jio AirFiber Custom";
    compatible = "qcom,ipq9574-ap-al02-c1", "qcom,ipq9574-al02", "qcom,ipq9574";
};

&pcie1_phy {
	status = "okay";
};

&pcie1 {
	pinctrl-0 = <&pcie1_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 26 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 27 GPIO_ACTIVE_LOW>;
	status = "okay";
};

&pcie2_phy {
	status = "okay";
};

&pcie2 {
	pinctrl-0 = <&pcie2_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 29 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 30 GPIO_ACTIVE_LOW>;
	status = "okay";
};

&pcie3_phy {
	status = "okay";
};

&pcie3 {
	pinctrl-0 = <&pcie3_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 32 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 33 GPIO_ACTIVE_LOW>;

	/* Forces the driver to wait for the controller's PLL to stabilize */
    qcom,perst-delay-us = <20000>;
    qcom,boot-delay-ms = <100>;
	
	status = "okay";
};

&mdio {
	// reset-gpios = <&tlmm 60 GPIO_ACTIVE_LOW>;
	clock-frequency = <6250000>;
	pinctrl-0 = <&mdio_pins>; /* Ensure mdio pinctrl is defined and matches */
	pinctrl-names = "default";
	status = "okay";

	ethernet-phy-package@0 {
		compatible = "qcom,qca8075-package";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x10>;
		qcom,package-mode = "qsgmii";

		phy0: ethernet-phy@10 {
			reg = <0x10>;
		};

		phy1: ethernet-phy@11 {
			reg = <0x11>;
		};

		phy2: ethernet-phy@12 {
			reg = <0x12>;
		};

		phy3: ethernet-phy@13 {
			reg = <0x13>;
		};

		phy5: ethernet-phy@0 {
			reg = <0x14>;
		};
	};

	// phy4: ethernet-phy@8 {
	// 	compatible ="ethernet-phy-ieee802.3-c45";
	// 	reg = <8>;

	// 	nvmem-cells = <&aqr_fw>;
	// 	nvmem-cell-names = "firmware";
	// };

};

&tlmm {

	pcie1_default: pcie1-default-state {
		clkreq-n-pins {
			pins = "gpio25";
			function = "pcie1_clk";
			drive-strength = <6>;
			bias-pull-up;
		};

		perst-n-pins {
			pins = "gpio26";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
			output-low;
		};

		wake-n-pins {
			pins = "gpio27";
			function = "pcie1_wake";
			drive-strength = <6>;
			bias-pull-up;
		};
	};

	pcie2_default: pcie2-default-state {
		clkreq-n-pins {
			pins = "gpio28";
			function = "pcie2_clk";
			drive-strength = <6>;
			bias-pull-up;
		};

		perst-n-pins {
			pins = "gpio29";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
			output-low;
		};

		wake-n-pins {
			pins = "gpio30";
			function = "pcie2_wake";
			drive-strength = <6>;
			bias-pull-up;
		};
	};

	pcie3_default: pcie3-default-state {
        clkreq-n-pins {
            pins = "gpio31";
            function = "pcie3_clk";
            drive-strength = <6>;
            bias-pull-up;
        };

        perst-n-pins {
            pins = "gpio32";
            function = "gpio";
            drive-strength = <8>;
            bias-pull-up;
            /* REMOVED: output-low; to prevent forcing a permanent hardware freeze */
        };

        wake-n-pins {
            pins = "gpio33";
            function = "pcie3_wake";
            drive-strength = <6>;
            bias-pull-up;
        };
    };
};

&qcom_ppe {
	ethernet-ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			phy-mode = "qsgmii";
			managed = "in-band-status";
			label = "wan";

			nvmem-cells = <&macaddr_art_0>;
			nvmem-cell-names = "mac-address";

			phy-handle = <&phy0>;
			pcs-handle = <&pcs0_ch0>;
			clocks = <&nsscc NSS_CC_PORT1_MAC_CLK>,
				 <&nsscc NSS_CC_PORT1_RX_CLK>,
				 <&nsscc NSS_CC_PORT1_TX_CLK>;
			clock-names = "mac",
				      "rx",
				      "tx";
			resets = <&nsscc PORT1_MAC_ARES>,
				 <&nsscc PORT1_RX_ARES>,
				 <&nsscc PORT1_TX_ARES>;
			reset-names = "mac",
				      "rx",
				      "tx";
		};

		port@2 {
			reg = <2>;
			phy-mode = "qsgmii";
			managed = "in-band-status";
			label = "lan1";

			nvmem-cells = <&macaddr_art_0>;
			nvmem-cell-names = "mac-address";

			phy-handle = <&phy1>;
			pcs-handle = <&pcs0_ch1>;
			clocks = <&nsscc NSS_CC_PORT2_MAC_CLK>,
				 <&nsscc NSS_CC_PORT2_RX_CLK>,
				 <&nsscc NSS_CC_PORT2_TX_CLK>;
			clock-names = "mac",
				      "rx",
				      "tx";
			resets = <&nsscc PORT2_MAC_ARES>,
				 <&nsscc PORT2_RX_ARES>,
				 <&nsscc PORT2_TX_ARES>;
			reset-names = "mac",
				      "rx",
				      "tx";
		};

		port@3 {
			reg = <3>;
			phy-mode = "qsgmii";
			managed = "in-band-status";
			label = "lan2";

			nvmem-cells = <&macaddr_art_0>;
			nvmem-cell-names = "mac-address";

			phy-handle = <&phy2>;
			pcs-handle = <&pcs0_ch2>;
			clocks = <&nsscc NSS_CC_PORT3_MAC_CLK>,
				 <&nsscc NSS_CC_PORT3_RX_CLK>,
				 <&nsscc NSS_CC_PORT3_TX_CLK>;
			clock-names = "mac",
				      "rx",
				      "tx";
			resets = <&nsscc PORT3_MAC_ARES>,
				 <&nsscc PORT3_RX_ARES>,
				 <&nsscc PORT3_TX_ARES>;
			reset-names = "mac",
				      "rx",
				      "tx";
		};

		port@4 {
			reg = <4>;
			phy-mode = "qsgmii";
			managed = "in-band-status";
			label = "lan3";

			nvmem-cells = <&macaddr_art_0>;
			nvmem-cell-names = "mac-address";

			phy-handle = <&phy3>;
			pcs-handle = <&pcs0_ch3>;
			clocks = <&nsscc NSS_CC_PORT4_MAC_CLK>,
				 <&nsscc NSS_CC_PORT4_RX_CLK>,
				 <&nsscc NSS_CC_PORT4_TX_CLK>;
			clock-names = "mac",
				      "rx",
				      "tx";
			resets = <&nsscc PORT4_MAC_ARES>,
				 <&nsscc PORT4_RX_ARES>,
				 <&nsscc PORT4_TX_ARES>;
			reset-names = "mac",
				      "rx",
				      "tx";
		};

		port@5 {
			status = "disabled";
		};

		// port@6 {
		// 	status = "disabled";
		// };

		// port@5 {
		// 	reg = <5>;
		// 	status = "disabled";
		// 	phy-mode = "usxgmii";
		// 	managed = "in-band-status";
		// 	label = "lan5";
		// 	phy-handle = <&phy4>;
		// 	pcs-handle = <&pcs1_ch0>;
		// 	clocks = <&nsscc NSS_CC_PORT5_MAC_CLK>,
		// 		 <&nsscc NSS_CC_PORT5_RX_CLK>,
		// 		 <&nsscc NSS_CC_PORT5_TX_CLK>;
		// 	clock-names = "mac",
		// 		      "rx",
		// 		      "tx";
		// 	resets = <&nsscc PORT5_MAC_ARES>,
		// 		 <&nsscc PORT5_RX_ARES>,
		// 		 <&nsscc PORT5_TX_ARES>;
		// 	reset-names = "mac",
		// 		      "rx",
		// 		      "tx";
		// };

		port@6 {
            reg = <6>;
            status = "okay";
            phy-mode = "qsgmii";
            managed = "in-band-status";
            label = "lan4";

			nvmem-cells = <&macaddr_art_0>;
			nvmem-cell-names = "mac-address";

            phy-handle = <&phy5>;
            pcs-handle = <&pcs2_ch0>;
            clocks = <&nsscc NSS_CC_PORT6_MAC_CLK>,
                     <&nsscc NSS_CC_PORT6_RX_CLK>,
                     <&nsscc NSS_CC_PORT6_TX_CLK>;
            clock-names = "mac", "rx", "tx";
            resets = <&nsscc PORT6_MAC_ARES>,
                     <&nsscc PORT6_RX_ARES>,
                     <&nsscc PORT6_TX_ARES>;
            reset-names = "mac", "rx", "tx";
        };
	};
};

/* Disable the nonexistent UNIPHY1 block entirely to prevent clock hang */
&pcs1 {
	status = "disabled";
};

/* If your dtsi includes an active PCS (Physical Coding Sublayer) node for uniphy1 */
&pcs2 {
	status = "okay";
	qcom,uniphy-mode = "qsgmii";
};

/* ---- FIX NAND ECC AND PARTITIONS ---- */
&qpic_nand {
    pinctrl-0 = <&qpic_snand_default_state>;
    pinctrl-names = "default";
    status = "okay";

	flash@0 {
		compatible = "spi-nand";
		reg = <0>;

		#address-cells = <1>;
		#size-cells = <1>;

		nand-ecc-engine = <&qpic_nand>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@00000000 {
				label = "0:sbl1";
				reg = <0x00000000 0x00180000>;
				read-only;
			};

			partition@00180000 {
				label = "0:sbl1_1";
				reg = <0x00180000 0x00180000>;
				read-only;
			};

			partition@00300000 {
				label = "0:mibib";
				reg = <0x00300000 0x00100000>;
				read-only;
			};

			partition@00400000 {
				label = "0:bootconfig";
				reg = <0x00400000 0x00080000>;
				read-only;
			};

			partition@00480000 {
				label = "0:bootconfig1";
				reg = <0x00480000 0x00080000>;
				read-only;
			};

			partition@00500000 {
				label = "0:qsee";
				reg = <0x00500000 0x00380000>;
				read-only;
			};

			partition@00880000 {
				label = "0:qsee_1";
				reg = <0x00880000 0x00380000>;
				read-only;
			};

			partition@00c00000 {
				label = "0:devcfg_1";
				reg = <0x00c00000 0x00080000>;
				read-only;
			};

			partition@00c80000 {
				label = "0:devcfg";
				reg = <0x00c80000 0x00080000>;
				read-only;
			};

			partition@00d00000 {
				label = "0:apdp_1";
				reg = <0x00d00000 0x00080000>;
				read-only;
			};

			partition@00d80000 {
				label = "0:apdp";
				reg = <0x00d80000 0x00080000>;
				read-only;
			};

			partition@00e00000 {
				label = "0:tme";
				reg = <0x00e00000 0x00080000>;
				read-only;
			};

			partition@00e80000 {
				label = "0:tme_1";
				reg = <0x00e80000 0x00080000>;
				read-only;
			};

			partition@00f00000 {
				label = "0:rpm_1";
				reg = <0x00f00000 0x00080000>;
				read-only;
			};

			partition@00f80000 {
				label = "0:rpm";
				reg = <0x00f80000 0x00080000>;
				read-only;
			};

			partition@01000000 {
				label = "0:cdt_1";
				reg = <0x01000000 0x00080000>;
				read-only;
			};

			partition@01080000 {
				label = "0:cdt";
				reg = <0x01080000 0x00080000>;
				read-only;
			};

			partition@01100000 {
				label = "0:appsblenv";
				reg = <0x01100000 0x00080000>;
			};

			partition@01180000 {
				label = "0:appsbl_1";
				reg = <0x01180000 0x00180000>;
				read-only;
			};

			partition@01300000 {
				label = "0:appsbl";
				reg = <0x01300000 0x00180000>;
				read-only;
			};

			partition@01480000 {
				compatible = "nvmem-cells";

				label = "0:art";
				reg = <0x01480000 0x00100000>;
				read-only;

				macaddr_art_0: macaddr@0 {
						reg = <0x0 0x6>;
				};
			};
			partition@01580000 {
				label = "0:ethphyfw";
				reg = <0x01580000 0x00100000>;
				read-only;
			};

			partition@01680000 {
				label = "0:training";
				reg = <0x01680000 0x00080000>;
				read-only;
			};

			partition@01700000 {
				label = "firmware";
				reg = <0x01700000 0x0a000000>;
				compatible = "denx,fit";
			};

			partition@0b700000 {
				label = "customfs";
				reg = <0x0b700000 0x04100000>;
				read-only;
			};

			partition@0f800000 {
				label = "jio-reserved";
				reg = <0x0f800000 0x00200000>;
				read-only;
			};

			partition@0fa00000 {
				label = "mfg";
				reg = <0x0fa00000 0x00200000>;
				read-only;
			};

			partition@0fc00000 {
				label = "0:bdf";
				reg = <0x0fc00000 0x00200000>;
				read-only;
			};
		};
	};
};